{
  "name": "presight-execise",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "build": "lerna run build",
    "db:migrate": "lerna run db:migrate --scope=presight-server",
    "db:seed": "lerna run db:seed --scope=presight-server",
    "predev": "yarn workspace @presight/shared build",
    "dev": "lerna run dev --parallel --scope=presight-client --scope=presight-server",
    "format": "prettier --write .",
    "lint": "yarn lint:eslint",
    "lint:eslint": "eslint .",
    "format:check": "prettier --check .",
    "start": "lerna run start",
    "test": "lerna run test",
    "typecheck": "lerna run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "lerna": "^8.2.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "dependencies": {
    "@dotenvx/dotenvx": "^2.14.0"
  }
}
